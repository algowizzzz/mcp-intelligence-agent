{
  "name": "sqlselect_execute_query",
  "implementation": "tools_pack_impl.sqlselect_execute_query.SqlselectExecuteQuery",
  "description": "Execute SQL SELECT queries on configured data sources with built-in safety checks and result limiting",
  "version": "2.9.8",
  "enabled": true,
  "data_sources": {
    "customers": {"file": "customers.csv", "type": "csv", "description": "Customer master data"},
    "orders":    {"file": "orders.csv",    "type": "csv", "description": "Order transactions"},
    "products":  {"file": "products.csv",  "type": "csv", "description": "Product catalog"},
    "sales":     {"file": "sales.csv",     "type": "csv", "description": "Sales data with customer and product details"}
  },
  "inputSchema": {
    "type": "object",
    "properties": {
      "query": {"type": "string", "description": "SQL SELECT query to execute"},
      "limit": {"type": "integer", "description": "Maximum rows to return", "default": 100, "minimum": 1, "maximum": 10000}
    },
    "required": ["query"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "success":   {"type": "boolean"},
      "columns":   {"type": "array"},
      "rows":      {"type": "array"},
      "row_count": {"type": "integer"},
      "query":     {"type": "string"},
      "timestamp": {"type": "string"}
    },
    "required": ["success", "columns", "rows", "row_count"]
  },
  "metadata": {
    "category": "Data Query",
    "tags": ["sql", "select", "query", "analytics", "duckdb"]
  }
}
