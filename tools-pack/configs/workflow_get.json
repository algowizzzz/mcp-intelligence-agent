{
  "name": "workflow_get",
  "implementation": "tools_pack_impl.workflow_get.WorkflowGet",
  "version": "1.0.0",
  "enabled": true,
  "category": "Workflow",
  "description": "Retrieve full markdown instructions for a workflow by filename. Execute the returned steps in order.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "filename": {
        "type": "string",
        "description": "MD filename from workflow_list e.g. counterparty_intelligence.md"
      },
      "_worker_context": {
        "type": "object",
        "description": "Injected by agent"
      }
    },
    "required": [
      "filename"
    ]
  },
  "metadata": {
    "category": "Workflow",
    "tags": [
      "workflow",
      "get",
      "fetch"
    ]
  }
}