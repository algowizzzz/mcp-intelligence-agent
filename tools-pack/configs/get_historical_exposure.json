{
  "name": "get_historical_exposure",
  "implementation": "tools_pack_impl.historical_exposure.HistoricalExposureTool",
  "description": "Retrieve historical counterparty exposure data for a specific quarter-end date",
  "version": "1.0.0",
  "enabled": true,
  "inputSchema": {
    "type": "object",
    "properties": {
      "date": {
        "type": "string",
        "description": "Quarter-end date in YYYY-MM-DD format (e.g. 2025-03-31, 2025-06-30, 2025-09-30, 2025-12-31)"
      },
      "counterparty": {
        "type": "string",
        "description": "Filter by counterparty name (optional). Returns all counterparties if omitted."
      },
      "_worker_context": {
        "type": "object",
        "description": "Injected by agent — worker scope dict"
      }
    },
    "required": ["date"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "counterparties": {"type": "array"},
      "_source": {"type": "string"}
    }
  },
  "metadata": {
    "author": "B-Pulse",
    "category": "Risk Data",
    "tags": ["historical", "exposure", "quarter-end"]
  }
}
