{
  "name": "document_search",
  "description": "BM25 full-text search across worker data layers (my_data, domain_data, common). Use for finding documents by free-text query. Supports md/txt/pdf/docx/xlsx/csv/json/yaml/py/rst.",
  "category": "Search",
  "version": "1.1.0",
  "enabled": true,
  "implementation": "tools_pack_impl.bm25_search.BM25SearchTool",
  "inputSchema": {
    "type": "object",
    "properties": {
      "query": {"type": "string", "description": "Free-text search query"},
      "top_k": {"type": "integer", "description": "Max results to return", "default": 10},
      "file_types": {"type": "array", "items": {"type": "string"}, "description": "Optional extension filter, e.g. ['.pdf', '.md']"},
      "top_n_full_content": {"type": "integer", "description": "Include full content for top N results", "default": 0},
      "_worker_context": {"type": "object", "description": "Injected by agent — worker scope dict"}
    },
    "required": ["query"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "query": {"type": "string"},
      "total_results": {"type": "integer"},
      "index_size": {"type": "integer"},
      "rebuilt": {"type": "boolean"},
      "results": {"type": "array"}
    }
  },
  "metadata": {
    "author": "B-Pulse",
    "category": "Search",
    "tags": ["bm25", "search", "fulltext", "documents"]
  }
}
