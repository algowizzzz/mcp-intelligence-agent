FROM nginx:alpine

# Copy HTML file
COPY mcp-agent.html /usr/share/nginx/html/index.html

# nginx config: serve on 8080, inject API_URL from env via envsubst
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 8080

CMD ["/bin/sh", "-c", \
  "envsubst '${API_URL}' < /usr/share/nginx/html/index.html > /tmp/index.html && \
   mv /tmp/index.html /usr/share/nginx/html/index.html && \
   nginx -g 'daemon off;'"]
