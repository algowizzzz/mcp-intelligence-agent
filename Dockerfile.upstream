###############################################################################
# B-Pulse Digital Workers — Upstream SAJHA + tools-pack image (REQ-17)
#
# Replaces our embedded sajhamcpserver/ fork with upstream
# (github.com/ajsinha/sajhamcpserver, v5.0.0 pinned via submodule).
# Our 31 custom tools live in tools-pack/ and are mounted into upstream
# via SAJHA_CONFIG_TOOLS_DIR + PYTHONPATH (no upstream source modification).
#
# Services (managed by supervisord):
#   1. SAJHA Upstream   — FastAPI/uvicorn on 127.0.0.1:3002 (internal only)
#   2. Agent Server     — FastAPI/uvicorn on 127.0.0.1:8000 (internal only)
#   3. nginx            — Reverse proxy + static files on $PORT (external)
###############################################################################

FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
        nginx supervisor gettext-base git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# ── Python deps: agent + upstream SAJHA + tools-pack ────────────────────────
COPY requirements.txt                              ./requirements.txt
COPY sajhamcpserver-upstream/requirements.txt      ./upstream-requirements.txt
COPY tools-pack/requirements.txt                   ./tools-pack-requirements.txt
RUN pip install --no-cache-dir \
        -r requirements.txt \
        -r upstream-requirements.txt \
        -r tools-pack-requirements.txt \
        pydantic-settings sse-starlette "python-jose[cryptography]"

# ── Python sandbox venv (python_execute) ─────────────────────────────────────
RUN python -m venv /app/python_sandbox_venv && \
    /app/python_sandbox_venv/bin/pip install --no-cache-dir \
        pandas numpy scipy matplotlib plotly openpyxl pyarrow statsmodels \
        scikit-learn arch riskfolio-lib networkx xarray

# ── App code: agent (we own) + upstream SAJHA (untouched) + tools-pack ─────
COPY agent/                       ./agent/
COPY agent_server.py              .
COPY public/                      ./public/
COPY sajhamcpserver-upstream/     ./sajhamcpserver-upstream/
COPY tools-pack/                  ./tools-pack/
COPY conftest.py                  .

# ── nginx + supervisord ───────────────────────────────────────────────────────
COPY nginx.conf                   /etc/nginx/templates/app.conf.template
COPY supervisord.upstream.conf    /etc/supervisor/conf.d/supervisord.conf
COPY scripts/start.sh             /start.sh
RUN chmod +x /start.sh && \
    rm -f /etc/nginx/conf.d/default.conf /etc/nginx/sites-enabled/default 2>/dev/null || true

# ── Runtime dirs ──────────────────────────────────────────────────────────────
RUN mkdir -p \
        /app/sajhamcpserver-upstream/logs \
        /app/sajhamcpserver-upstream/data \
        /app/data \
        /var/log /var/run

# ── Defaults ─────────────────────────────────────────────────────────────────
ENV PYTHONUNBUFFERED=1 \
    PORT=80 \
    SAJHA_BASE_URL=http://127.0.0.1:3002 \
    SAJHA_AUTH_MODE=jwt \
    SAJHA_ADMIN_USER=admin \
    SAJHA_ADMIN_PASS=admin123 \
    SAJHA_CONFIG_TOOLS_DIR=/app/tools-pack/configs \
    PYTHONPATH=/app/tools-pack:/app

EXPOSE 80
CMD ["/start.sh"]
